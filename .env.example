# Host paths for runtime state and source mounts.
MEMORY_DATA_DIR=/srv/memory-hub
MEMORY_INGEST_DIR=/srv/ingest
MEMORY_OBSIDIAN_DIR=/srv/ingest/obsidian

# Public surface. Use this if you front the dashboard/gateway with a reverse proxy.
MEMORY_PUBLIC_ORIGIN=https://your-memory-domain.example

# Backend / gateway / admin tokens.
AGENTMEMORY_TOKEN=replace-with-backend-token
MEMORY_BACKEND_URL=http://agentmemory:3111
MEMORY_BACKEND_TOKEN=replace-with-gateway-backend-token
MEMORY_GATEWAY_TOKEN=replace-with-agent-token
MEMORY_ADMIN_TOKEN=replace-with-admin-token
GITHUB_TOKEN=replace-with-github-access-token

# Optional public MCP host/origin allowlists.
MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,memory-agent-gateway:*
MCP_ALLOWED_ORIGINS=

# Backend runtime defaults.
POSTGRES_DB=agentmemory
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_HOST=memory-db
POSTGRES_PORT=5432
OLLAMA_HOST=http://ollama:11434
DEFAULT_MODEL=qwen3-embedding:4b
EMBEDDING_DIMS=2560
EMBEDDING_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-2
GEMINI_OUTPUT_DIMENSIONALITY=2560
GEMINI_CONCURRENCY=4
REQUEST_TIMEOUT_SECONDS=120
GEMINI_RETRY_SLEEP_SECONDS=2
VECTOR_INDEX_EF_SEARCH=100
LEXICAL_INDEX_CATEGORIES=agent,emails,obsidian,documents
SEARCH_LEXICAL_TIMEOUT_MS=800
SEARCH_LEXICAL_MAX_CHARS=50000
EMBED_CACHE_TTL_SECONDS=3600
EMBED_CACHE_MAX_ITEMS=512
MEMORY_CATEGORIES=agent,emails,obsidian,documents,code
EMBED_CHUNK_SIZE=1500
EMBED_CHUNK_OVERLAP=150
EMBED_RETRY_MIN_CHUNK=256

# Ingestion worker defaults.
AGENTMEMORY_URL=http://agentmemory:3111
MEMORY_GATEWAY_URL=http://memory-agent-gateway:3112
DOCS_SLEEP_INTERVAL=300
EMAIL_BATCH_SIZE=2000
EMAIL_SLEEP_INTERVAL=60
OBSIDIAN_SLEEP_INTERVAL=60
GITHUB_USERNAME=replace-with-github-username
GITHUB_SLEEP_INTERVAL=3600

# Enrichment defaults.
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_FREE_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=deepseek-v4-flash
LLM_REASONING_EFFORT=low
LLM_API_KEY=replace-with-primary-llm-token
LLM_FALLBACK_API_KEY=replace-with-fallback-llm-token
ENRICH_BATCH_SIZE=100
ENRICH_CONCURRENCY=50
GEMINI_CONCURRENCY=8

# Browser/dashboard ports.
GATEWAY_PORT=3112
DASHBOARD_PORT=3000

# Optional backup cadence and retention.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
