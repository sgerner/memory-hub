# The existing internal Memorex API bearer token. Do not give this to agents.
MEMORY_BACKEND_TOKEN=replace-with-current-backend-token

# Token presented by MCP clients and the CLI. Generate independently of the backend token.
MEMORY_GATEWAY_TOKEN=replace-with-agent-token

# Token reserved for irreversible DELETE requests; do not configure it in agents.
MEMORY_ADMIN_TOKEN=replace-with-admin-token

# Add the public reverse-proxy hostname that agents will use.
MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,memory-agent-gateway:*,memory.example.com
# Set only when browser-based MCP clients are used.
MCP_ALLOWED_ORIGINS=
